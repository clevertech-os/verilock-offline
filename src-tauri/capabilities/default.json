{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default window capabilities for VeriLock Offline",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-fetch-json",
    "allow-fetch-image-data-url",
    "allow-login-via-system-browser",
    "allow-open-external-url",
    "allow-open-print-html"
  ]
}
